DATABASE_URL=postgres://postgres:clipchat@localhost:5432/clipchat
REDIS_URL=redis://localhost:6379
STORAGE_DRIVER=local          # local | s3
UPLOAD_DIR=./uploads

# S3 (when STORAGE_DRIVER=s3)
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=                  # Optional: for MinIO / compatible

PORT=3000
WORKER_CONCURRENCY=2

# Phase 2 — AI layer (OpenRouter)
OPENROUTER_API_KEY=            # Required for /api/v1/chat — get a key at openrouter.ai
OPENROUTER_MODEL=anthropic/claude-opus-4
