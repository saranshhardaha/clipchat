DATABASE_URL=postgres://postgres:clipchat@localhost:5432/clipchat
REDIS_URL=redis://localhost:6379
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# S3 (when STORAGE_DRIVER=s3)
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=

PORT=3000
WORKER_CONCURRENCY=2

# AI — required for /api/v1/chat
OPENROUTER_API_KEY=           # Required. Get a key at https://openrouter.ai
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Web UI
ENGINE_URL=http://localhost:3000
ENGINE_API_KEY=               # Generate: npm run create-api-key -w packages/engine -- "dev"
                              # Or run ./setup.sh which generates and saves this automatically
